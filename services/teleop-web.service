[Unit]
Description=Omni Robot Web Teleop UI
After=network-online.target omni-bridge.service
Wants=network-online.target
Requires=omni-bridge.service

[Service]
Type=simple
User=noob
EnvironmentFile=-/etc/omni-robot/omni.env
ExecStart=/bin/bash -lc 'exec "${OMNI_HOME:-/home/noob/omni-pi}/tools/run_teleop_web.sh"'
Restart=always
RestartSec=2
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
