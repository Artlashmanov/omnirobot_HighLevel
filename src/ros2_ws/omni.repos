# External ROS source dependencies for omnirobot HighLevel.
# Paths are relative to src/ros2_ws, so import with:
#   cd src/ros2_ws
#   vcs import --input omni.repos .
repositories:
  src/sllidar_ros2:
    type: git
    url: https://github.com/Slamtec/sllidar_ros2.git
    version: 34300099fadfc772965962dec837bf436706188f
